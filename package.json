{
  "name": "klawd-nexus",
  "productName": "Klawd Nexus",
  "version": "1.0.0",
  "description": "Multi-terminal Claude Code command center",
  "main": "electron.js",
  "scripts": {
    "build": "esbuild src/app.js --bundle --outfile=public/js/bundle.js --format=iife --platform=browser --target=es2020 --minify",
    "build:dev": "esbuild src/app.js --bundle --outfile=public/js/bundle.js --format=iife --platform=browser --target=es2020 --sourcemap",
    "start": "npm run build && node server.js",
    "app": "electron .",
    "dev": "concurrently \"esbuild src/app.js --bundle --outfile=public/js/bundle.js --format=iife --platform=browser --target=es2020 --sourcemap --watch\" \"node server.js\""
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "express": "^4.21.0",
    "node-pty": "^1.2.0-beta.12",
    "qrcode": "^1.5.4",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "electron": "^41.1.0",
    "esbuild": "^0.24.0"
  }
}
